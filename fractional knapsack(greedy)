#include <stdio.h>

int main()
{
    int n, i, j;
    float w[10], p[10], ratio[10];
    float temp, capacity, profit = 0;

    printf("Enter number of items: ");
    scanf("%d", &n);

    if (n <= 0 || n > 10)
    {
        printf("Invalid number of items\n");
        return 0;
    }

    // Input weights and profits
    for (i = 0; i < n; i++)
    {
        printf("Enter weight and profit of item %d: ", i + 1);
        scanf("%f %f", &w[i], &p[i]);
        ratio[i] = p[i] / w[i];
    }

    printf("Enter knapsack capacity: ");
    scanf("%f", &capacity);

    // Sort items based on ratio (descending)
    for (i = 0; i < n - 1; i++)
    {
        for (j = i + 1; j < n; j++)
        {
            if (ratio[i] < ratio[j])
            {
                // Swap ratio
                temp = ratio[i];
                ratio[i] = ratio[j];
                ratio[j] = temp;

                // Swap weights
                temp = w[i];
                w[i] = w[j];
                w[j] = temp;

                // Swap profits
                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    // Apply Fractional Knapsack
    for (i = 0; i < n; i++)
    {
        if (capacity >= w[i])
        {
            capacity -= w[i];
            profit += p[i];
            printf("Item %d taken completely\n", i + 1);
        }
        else
        {
            profit += ratio[i] * capacity;
            printf("Item %d taken partially\n", i + 1);
            break;
        }
    }

    printf("Maximum profit = %.2f\n", profit);

    return 0;
}
