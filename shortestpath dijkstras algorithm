#include <stdio.h>
#include <limits.h>

int main()
{
    int n, i, j, src;
    int cost[10][10], dist[10], visited[10] = {0};

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    if (n <= 0 || n > 10)
    {
        printf("Invalid input\n");
        return 0;
    }

    printf("Enter adjacency matrix:\n");
    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
        {
            scanf("%d", &cost[i][j]);

            // Replace 0 with infinity (no edge), except diagonal
            if (i != j && cost[i][j] == 0)
                cost[i][j] = INT_MAX;
        }
    }

    printf("Enter source vertex (0 to %d): ", n - 1);
    scanf("%d", &src);

    // Initialize distances
    for (i = 0; i < n; i++)
    {
        dist[i] = cost[src][i];
        visited[i] = 0;
    }

    dist[src] = 0;
    visited[src] = 1;

    // Dijkstra’s Algorithm
    for (i = 1; i < n; i++)
    {
        int min = INT_MAX, u = -1;

        // Find minimum distance vertex
        for (j = 0; j < n; j++)
        {
            if (!visited[j] && dist[j] < min)
            {
                min = dist[j];
                u = j;
            }
        }

        if (u == -1) break;

        visited[u] = 1;

        // Update distances
        for (j = 0; j < n; j++)
        {
            if (!visited[j] && cost[u][j] != INT_MAX &&
                dist[u] + cost[u][j] < dist[j])
            {
                dist[j] = dist[u] + cost[u][j];
            }
        }
    }

    printf("\nShortest distances from vertex %d:\n", src);
    for (i = 0; i < n; i++)
    {
        if (dist[i] == INT_MAX)
            printf("%d -> %d = INF\n", src, i);
        else
            printf("%d -> %d = %d\n", src, i, dist[i]);
    }

    return 0;
}
